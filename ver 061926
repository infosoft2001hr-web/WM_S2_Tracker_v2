var SEARCH_RESULTS=[];
function normName(s){return (s||'').toLowerCase().replace(/[.,()]/g,' ').replace(/\s+/g,' ').trim();}
function hlName(name,tokens){
  var esc=name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  var valid=tokens.filter(function(t){return t.length>=2;}).map(function(t){return t.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');});
  if(!valid.length)return esc;
  var re=new RegExp('('+valid.join('|')+')','ig');
  return esc.replace(re,'<mark class="hl">$1</mark>');
}
function doSearch(q){
  var raw=q.trim();
  var query=normName(raw);
  var res=document.getElementById('myResult');
  if(query.length<2){res.classList.remove('visible');document.getElementById('myEmpty').style.display='block';document.getElementById('disputeSection').style.display='none';return;}
  document.getElementById('myEmpty').style.display='none';
  var pools=[['Stride',D.stride],['Plus 1',D.guests],['Ride',D.ride]];
  var tokens=query.split(' ').filter(Boolean);
  var matches=[];
  pools.forEach(function(p){p[1].forEach(function(a){
    var n=normName(a.name);
    if(tokens.every(function(t){return n.indexOf(t)!==-1;})){
      var sc=0; if(n.indexOf(query)===0)sc+=3; else if(n.indexOf(query)!==-1)sc+=2;
      matches.push({a:a,disc:p[0],score:sc});
    }
  });});
  matches.sort(function(x,y){return y.score-x.score || x.a.name.localeCompare(y.a.name);});
  SEARCH_RESULTS=matches;
  if(!matches.length){
    res.innerHTML='<div class="my-card"><div class="my-not-found"><div class="empty-icon">&#128269;</div><p>No athlete found for "<strong>'+raw+'</strong>".<br>Try part of your first or last name.</p></div></div>';
    res.classList.add('visible');document.getElementById('disputeSection').style.display='none';return;
  }
  if(matches.length>1){
    var list=matches.map(function(o,i){
      var c=catColor(catKey(o.a.category));
      return '<button class="pick-row" onclick="selectAthlete('+i+')">'
        +'<span class="pick-name">'+hlName(o.a.name,tokens)+'</span>'
        +'<span class="pick-meta"><span class="pick-disc">'+o.disc+'</span> &middot; <span style="color:'+c+'">'+catLabel(catKey(o.a.category))+'</span> &middot; '+o.a.group.replace(/^G\d+ - /,'')+' &middot; '+o.a.site+'</span></button>';
    }).join('');
