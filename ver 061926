function getPrevWeek(){
  // Disputable week, aligned with the 'data as of' badge:
  // Week 1 now (current week); from Week 2 onward, the previous (completed) week.
  var start=new Date(2026,5,15);
  var now=new Date();
  var today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
  var cw=Math.floor((today-start)/86400000/7)+1;
  if(cw<1) cw=1; if(cw>13) cw=13;
  var asof=(cw===1)?1:cw-1;
  return asof-1;   // 0-based index into WEEKS[]; never null so the form is always open
}
