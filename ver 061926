  <div class="footer">Wellness Move 2026 &middot; Season 2 &nbsp;&middot;&nbsp; Presented by <strong>INFOSOFT CONSULTING CORPORATION</strong> &nbsp;&middot;&nbsp; Generated June 18, 2026</div>
</div>

<script>
let D = { stride:[], guests:[], ride:[], weeks:[], meta:{} };
let WEEKS = [];
let activeWeek = null;
let activeTab  = 'home';
let sectionCounter = 0;

function catKey(c){c=(c||'').toLowerCase();if(c.includes('elite'))return 'elite';if(c.includes('igniter'))return 'igniter';if(c.includes('challenger'))return 'challenger';if(c.includes('enduro'))return 'enduro';if(c.includes('ascend'))return 'ascend';return 'other';}
function catColor(k){return{elite:'var(--elite)',igniter:'var(--igniter)',challenger:'var(--challenger)',enduro:'var(--enduro)',ascend:'var(--ascend)'}[k]||'var(--text2)';}
function catIcon(k){return{elite:'&#127945;',igniter:'&#127944;',challenger:'&#127943;',enduro:'&#128692;',ascend:'&#127956;'}[k]||'&#127941;';}
function catGoal(k){return{elite:'300 KM Goal',igniter:'100 KM Goal',challenger:'50 KM Goal',enduro:'750 KM Goal',ascend:'400 KM Goal'}[k]||'';}
function catLabel(k){return{elite:'ELITE',igniter:'IGNITER',challenger:'CHALLENGER',enduro:'ENDURO',ascend:'ASCEND'}[k]||k.toUpperCase();}
function progGrad(p){if(p>=1)return 'linear-gradient(90deg,#14F195,#00D4AA)';if(p>=.75)return 'linear-gradient(90deg,#38BDF8,#14F195)';if(p>=.5)return 'linear-gradient(90deg,#2563EB,#38BDF8)';return 'linear-gradient(90deg,#A855F7,#2563EB)';}
function rankClass(i){return['r1','r2','r3'][i]||'rn';}
function fmtKm(v){return v>0?v.toFixed(2):'—';}
function getKm(a){return a.total;}
function getProgress(a){return a.progress;}
function curWeek(){const t=new Date(),s=new Date('2026-06-15');return Math.min(12,Math.max(0,Math.floor((t-s)/(7*86400000))));}

function renderHero(){ /* hero pills removed */ }

/* week bar removed — always season totals */

function toggleSection(id){
  const hdr=document.getElementById('hdr-'+id),body=document.getElementById('body-'+id);
  const open=hdr.classList.contains('open');
  hdr.classList.toggle('open',!open);body.classList.toggle('open',!open);
  hdr.setAttribute('aria-expanded',(!open).toString());
}

function buildGenderPanel(athletes,catk,sex){
  const isFem=sex==='F',color=catColor(catk);
  const sexColor=isFem?'#F472B6':'#38BDF8';
  const sexBadgeCls=isFem?'sex-badge sex-f':'sex-badge sex-m';
  const sexLblCls=isFem?'sex-lbl sex-f-lbl':'sex-lbl sex-m-lbl';
  const sexIcon=isFem?'&#128105;':'&#128104;';
  const sexLabel=isFem?'FEMALE':'MALE';
  const sorted=[...athletes]
    .filter(a=>catKey(a.category)===catk&&a.sex===sex)
    .sort((a,b)=>getKm(b)-getKm(a)||a.name.localeCompare(b.name));
  const top=sorted.slice(0,10);
  const rows=top.map((a,i)=>{
    const km=getKm(a),pct=Math.round(getProgress(a)*100);
    const fin=a.total>=a.goal&&a.goal>0&&activeWeek===null;
    const finTag=fin?'<span class="fin-tag">&#127941; Goal</span>':'';
    return `<div class="cat-row ${fin?'finished':''}">
      <div class="rank-ico ${rankClass(i)}">${i+1}</div>
      <div class="cat-row-info">
        <div class="cat-row-name">${a.name}${finTag}</div>
        <div class="cat-row-sub">${a.group.replace(/^G\d+ - /,'')}</div>
        <div class="cat-prog"><div class="cat-prog-fill" style="width:${Math.min(100,pct)}%;background:${progGrad(pct/100)};"></div></div>
      </div>
      <div class="cat-row-right">
        <div class="cat-km" style="color:${fin?'var(--green)':color};">${fmtKm(km)}</div>
        <div class="cat-pct">${km>0?pct+'%':'—'}</div>
      </div>
    </div>`;
  }).join('');
  const more=sorted.length>10?`<div style="text-align:center;padding:6px;font-size:.67rem;color:var(--text2);">+${sorted.length-10} more</div>`:'';
  return `<div class="cat-panel" style="border-top:3px solid ${sexColor};">
    <div class="cat-hdr">
      <div class="cat-hdr-left">
        <div class="${sexBadgeCls}">${sexIcon}</div>
        <span class="${sexLblCls}">${sexLabel}</span>
      </div>
      <div class="cat-count">Top ${Math.min(10,sorted.length)} of ${sorted.length}</div>
    </div>
    <div class="cat-list">${rows}</div>${more}
  </div>`;
}

function buildCatSection(athletes,catk){
  if(!athletes.some(a=>catKey(a.category)===catk))return '';
  const color=catColor(catk);
  const mCount=athletes.filter(a=>catKey(a.category)===catk&&a.sex==='M').length;
  const fCount=athletes.filter(a=>catKey(a.category)===catk&&a.sex==='F').length;
  const id='cat-'+(++sectionCounter);
  return `<div class="cat-section">
    <div class="cat-section-hdr" id="hdr-${id}" role="button" tabindex="0" aria-expanded="false" aria-controls="body-${id}" onclick="toggleSection('${id}')" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();toggleSection('${id}');}">
      <span class="cat-section-icon">${catIcon(catk)}</span>
      <span class="cat-section-name" style="color:${color};">${catLabel(catk)}</span>
      <span class="cat-section-goal">${catGoal(catk)}</span>
      <div class="cat-section-counts">
        <span class="cnt-m">&#128104; ${mCount}M</span>
        <span class="cnt-f">&#128105; ${fCount}F</span>
      </div>
      <span class="cat-chevron">&#9660;</span>
    </div>
    <div class="gender-pair" id="body-${id}">
      ${buildGenderPanel(athletes,catk,'M')}
      ${buildGenderPanel(athletes,catk,'F')}
    </div>
  </div>`;
}

function buildTop10Panel(athletes,label,color,accentCss){
  const sorted=[...athletes].sort((a,b)=>getKm(b)-getKm(a)||a.name.localeCompare(b.name)).slice(0,10);
  const rows=sorted.map((a,i)=>{
    const km=getKm(a),pct=Math.round(getProgress(a)*100);
    const fin=a.total>=a.goal&&a.goal>0&&activeWeek===null;
    const finTag=fin?'<span class="fin-tag">&#127941; Goal</span>':'';
    const ck=catKey(a.category);
    const catBg={'elite':'rgba(168,85,247,.2)','igniter':'rgba(56,189,248,.2)','challenger':'rgba(20,241,149,.2)','enduro':'rgba(251,113,133,.2)','ascend':'rgba(251,191,36,.2)'}[ck]||'rgba(255,255,255,.1)';
    const catTxt=catColor(ck);
    const sexChip=a.sex==='F'?'<span class="sex-chip sex-chip-f">F</span>':'<span class="sex-chip sex-chip-m">M</span>';
    return `<div class="top10-row ${fin?'finished':''}">
      <div class="rank-ico ${rankClass(i)}">${i+1}</div>
      <div class="cat-row-info">
        <div class="cat-row-name">${a.name}${finTag}</div>
        <div class="cat-row-sub">${a.group.replace(/^G\d+ - /,'')}</div>
        <div class="cat-prog"><div class="cat-prog-fill" style="width:${Math.min(100,pct)}%;background:${progGrad(pct/100)};"></div></div>
      </div>
      ${sexChip}
      <span class="top10-cat-badge" style="background:${catBg};border:1px solid ${catTxt};color:${catTxt};">${catLabel(ck)}</span>
      <div class="cat-row-right">
        <div class="cat-km" style="color:${fin?'var(--green)':color};">${fmtKm(km)}</div>
      </div>
    </div>`;
  }).join('');
  return `<div class="top10-card">
    <div class="top10-hdr" style="border-bottom-color:${accentCss};background:linear-gradient(135deg,${accentCss.replace('1)','0.07)')},transparent);">
      <span class="top10-hdr-icon">&#127942;</span>
      <span class="top10-hdr-title" style="color:${color};">TOP 10 — ${label}</span>
      <span class="top10-hdr-sub">All categories &middot; by KM</span>
    </div>
    <div class="top10-body">${rows}</div>
  </div>`;
}

function renderHome(){
  const m=D.meta;
  const cards=[
    {key:'stride',cls:'nc-stride',icon:'&#127939;',title:'STRIDE',meta:'Running / Walking / Hiking',stat:`${m.strideCount} Employees`},
    {key:'ride',cls:'nc-ride',icon:'&#128692;',title:'RIDE',meta:'Cycling',stat:`${m.rideCount} Employees`},
    {key:'plus1',cls:'nc-plus1',icon:'&#128101;',title:'PLUS 1 GUESTS',meta:'Family & Friends',stat:`${m.guestCount} Registered`},
    {key:'groups',cls:'nc-groups',icon:'&#127968;',title:'GROUP ACHIEVEMENT',meta:'Team Rankings',stat:`${Object.keys([...D.stride,...D.guests,...D.ride].reduce((a,x)=>{a[x.group]=1;return a},{})).length} Groups`},
    {key:'mine',cls:'nc-mine',icon:'&#128269;',title:'MY PROGRESS',meta:'Find your ranking & submit corrections',stat:'Search by name'},
  ];
  document.getElementById('navGrid').innerHTML=cards.map(c=>
    `<div class="nav-card ${c.cls}" role="button" tabindex="0" onclick="switchTab('${c.key}')" onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();switchTab('${c.key}');}">
      <span class="nav-card-icon">${c.icon}</span>
      <div class="nav-card-title">${c.title}</div>
      <div class="nav-card-meta">${c.meta}</div>
      <div class="nav-card-stat">${c.stat}</div>
      <div class="nav-card-cta">${c.key==='mine'?'Open':'View'} <span class="ar">&#8594;</span></div>
    </div>`
  ).join('');
  document.getElementById('homeTop10').innerHTML=
    buildTop10Panel(D.stride,'STRIDE','#93C5FD','rgba(37,99,235,1)')+
    buildTop10Panel(D.ride,'RIDE','#FCA5A5','rgba(251,113,133,1)');
  renderCombinedBanner();
}

function renderCombinedBanner(){
  const m=D.meta;
  const sumGoals=arr=>arr.reduce((a,x)=>a+(+x.goal||0),0);
  const strideTarget=sumGoals(D.stride)+sumGoals(D.guests);
  const rideTarget=sumGoals(D.ride);
  const combined=strideTarget+rideTarget;
  const achieved=+(m.totalKm||0);
  const regs=D.stride.length+D.guests.length+D.ride.length;
  const pct=combined>0?Math.min(100,achieved/combined*100):0;
  const fmt=n=>Math.round(n).toLocaleString('en-US');
  const el=document.getElementById('combinedBanner');
  if(!el)return;
  el.innerHTML=
    '<div class="cb-inner">'+
      '<div class="cb-eyebrow">Combined KM Target &amp; Achieved</div>'+
      '<div class="cb-big"><span data-count="'+combined+'">0</span> <span class="cb-unit">KM</span></div>'+
      '<div class="cb-achieved">&#127937; Achieved so far: <span class="cb-ach-num" data-count="'+achieved+'">0</span> KM '+
        '<span style="opacity:.6">('+pct.toFixed(1)+'%)</span></div>'+
      '<div class="cb-bar"><div class="cb-bar-fill" id="cbBarFill"></div></div>'+
      '<div class="cb-breakdown"><span>&#127939; Stride: <span class="s" data-count="'+strideTarget+'">0</span> KM</span>'+
        '<span class="dot">&middot;</span>'+
        '<span>&#128692; Ride: <span class="r" data-count="'+rideTarget+'">0</span> KM</span></div>'+
      '<div class="cb-foot">'+regs+' Total Registrations &middot; Live from Google Sheet</div>'+
    '</div>';
  // animate the numbers counting up
  el.querySelectorAll('[data-count]').forEach(node=>{
    const target=+node.getAttribute('data-count');
    const dur=1400, start=performance.now();
    function step(now){
      const t=Math.min(1,(now-start)/dur);
      const eased=1-Math.pow(1-t,3);
      node.textContent=Math.round(target*eased).toLocaleString('en-US');
      if(t<1)requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  });
  // animate the progress bar
  requestAnimationFrame(()=>{const b=document.getElementById('cbBarFill');if(b)b.style.width=pct+'%';});
}

function renderStride(){
  sectionCounter=0;
  let h='';['elite','igniter','challenger'].forEach(k=>h+=buildCatSection(D.stride,k));
  document.getElementById('stride-panels').innerHTML=h;
}
function renderRide(){
  sectionCounter=0;
  let h='';['enduro','ascend'].forEach(k=>h+=buildCatSection(D.ride,k));
  document.getElementById('ride-panels').innerHTML=h;
}
function renderPlus1(){
  const guests=[...D.guests].sort((a,b)=>getKm(b)-getKm(a)||a.name.localeCompare(b.name));
  const rows=guests.map((a,i)=>{
