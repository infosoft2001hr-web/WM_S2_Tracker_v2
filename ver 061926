/* ===== SEARCH MATCH HIGHLIGHT ===== */
.hl{background:rgba(0,212,255,.28);color:#fff;border-radius:3px;padding:0 2px;}
.light .hl{background:rgba(37,99,235,.2);color:#0F172A;}

/* ===== SEARCH CANDIDATE PICKER ===== */
.pick-hdr{padding:15px 18px 12px;font-size:.84rem;color:var(--text2);border-bottom:1px solid rgba(255,255,255,.07);}
.pick-list{padding:7px;}
.pick-row{display:flex;flex-direction:column;gap:2px;width:100%;text-align:left;cursor:pointer;
  background:rgba(255,255,255,.04);border:1px solid var(--card-border);border-radius:10px;
  padding:10px 13px;margin:5px 0;transition:.18s;font-family:'Outfit',sans-serif;color:var(--text);}
.pick-row:hover{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.45);transform:translateX(2px);}
.pick-name{font-weight:700;font-size:.92rem;}
.pick-meta{font-size:.66rem;color:var(--text2);}
.pick-disc{color:var(--blue-bright);font-weight:700;}

/* ===== REDUCED MOTION ===== */
@media(prefers-reduced-motion:reduce){
  .bg::before,.wm-logo,.nc-mine,.nav-card-cta,.dot,.pane,.modal,.cb-big,.cb-bar-fill,.combined-banner::before{animation:none!important;}
  *{scroll-behavior:auto!important;}
}

