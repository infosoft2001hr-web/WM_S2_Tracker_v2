/* ===== Moving particles — float/rise upward like bubbles ===== */
(function(){
  var canvas=document.getElementById('particles');
  if(!canvas)return;
  var reduce=window.matchMedia&&window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var ctx=canvas.getContext('2d');
  var dpr=Math.min(window.devicePixelRatio||1,2);
  var W=0,H=0,particles=[];
  var COLORS=[[0,212,255],[20,241,149],[168,85,247],[216,180,254],[110,231,183]];
  function rand(a,b){return a+Math.random()*(b-a);}
  function makeParticle(atBottom){
    var c=COLORS[(Math.random()*COLORS.length)|0];
    return {
      x:rand(0,W),
      y:atBottom?H+rand(0,40):rand(0,H),
      r:rand(1,2.8),
      vy:rand(0.18,0.55),            // upward speed
      drift:rand(-0.14,0.14),        // gentle horizontal sway base
      sway:rand(0.4,1.1),            // sway frequency
      phase:rand(0,Math.PI*2),
      color:c,
      baseA:rand(0.35,0.9),
      tw:rand(0,Math.PI*2),tws:rand(0.6,1.6)
    };
  }
  function resize(){
    W=canvas.clientWidth;H=canvas.clientHeight;
    canvas.width=W*dpr;canvas.height=H*dpr;
    ctx.setTransform(dpr,0,0,dpr,0,0);
    var target=Math.round(Math.min(46,Math.max(16,(W*H)/26000)));
    particles=[];
    for(var i=0;i<target;i++)particles.push(makeParticle(false));
  }
  function draw(t){
    ctx.clearRect(0,0,W,H);
    for(var i=0;i<particles.length;i++){
      var p=particles[i];
      p.y-=p.vy;                                   // rise
      p.x+=p.drift+Math.sin(t*0.0006*p.sway+p.phase)*0.25;  // gentle sway
      // fade out as it nears the top
      var lifeA=p.y<H*0.18?Math.max(0,p.y/(H*0.18)):1;
      if(p.y<-12){Object.assign(p,makeParticle(true));continue;}
      if(p.x<-12)p.x=W+12;else if(p.x>W+12)p.x=-12;
      var a=p.baseA*lifeA*(0.6+0.4*Math.sin(t*0.001*p.tws+p.tw));
      var c=p.color;
      ctx.beginPath();
      var g=ctx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*5);
      g.addColorStop(0,'rgba('+c[0]+','+c[1]+','+c[2]+','+a+')');
      g.addColorStop(0.4,'rgba('+c[0]+','+c[1]+','+c[2]+','+(a*0.35)+')');
      g.addColorStop(1,'rgba('+c[0]+','+c[1]+','+c[2]+',0)');
      ctx.fillStyle=g;
      ctx.arc(p.x,p.y,p.r*5,0,Math.PI*2);
      ctx.fill();
      ctx.beginPath();
      ctx.fillStyle='rgba('+c[0]+','+c[1]+','+c[2]+','+Math.min(1,a+0.15)+')';
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fill();
    }
    requestAnimationFrame(draw);
  }
  function drawStatic(){
    ctx.clearRect(0,0,W,H);
    for(var i=0;i<particles.length;i++){
      var p=particles[i],c=p.color;
      ctx.beginPath();
      ctx.fillStyle='rgba('+c[0]+','+c[1]+','+c[2]+','+p.baseA+')';
      ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fill();
    }
  }
  resize();
  var rt;window.addEventListener('resize',function(){clearTimeout(rt);rt=setTimeout(function(){resize();if(reduce)drawStatic();},150);});
  if(reduce)drawStatic();else requestAnimationFrame(draw);
})();
</script>

<script>
/* Data-as-of indicator — challenge runs 1 week behind on updates.
   Shows the most recently completed week; auto-advances every Monday. */
(function(){
  function render(){
    var el=document.getElementById('data-asof');
    if(!el) return;
    var start=new Date(2026,5,15);
    var now=new Date();
    var today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
    var cw=Math.floor((today-start)/86400000/7)+1;   // current week (1-based)
    if(cw<1) cw=1; if(cw>13) cw=13;
    var asof=(cw===1)?1:cw-1;   // this week shows the current week; from Week 2 on, shows the previous (completed) week
    var dates=(typeof D!=='undefined' && D.weeks && D.weeks[asof-1]) ? D.weeks[asof-1] : '';
    el.innerHTML='&#128197;&nbsp;Showing data as of <b>Week '+asof+'</b>'+(dates?' &nbsp;&middot;&nbsp; '+dates:'');
  }
  if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',render);
  else render();
})();
</script>
