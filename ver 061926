<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Wellness Move 2026 S2 Leaderboard</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{
  --blue:#2563EB;--blue-glow:#38BDF8;--blue-bright:#00D4FF;
  --violet:#A855F7;--violet-glow:#D8B4FE;
  --green:#14F195;--green-glow:#6EE7B7;
  --darker:#050813;--card-bg:rgba(13,19,38,0.72);--card-border:rgba(56,189,248,0.15);
  --text:#F1F5F9;--text2:rgba(241,245,249,0.72);
  --elite:#A855F7;--igniter:#38BDF8;--challenger:#14F195;
  --enduro:#FB7185;--ascend:#FBBF24;--gold:#FFD700;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{font-size:14px;}
body{font-family:'Outfit',sans-serif;background:var(--darker);color:var(--text);min-height:100vh;overflow-x:hidden;}
.bg{position:fixed;inset:0;z-index:0;pointer-events:none;}
.bg::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;
  background:radial-gradient(circle at 15% 20%,rgba(37,99,235,.18)0%,transparent 40%),
            radial-gradient(circle at 85% 25%,rgba(168,85,247,.15)0%,transparent 40%),
            radial-gradient(circle at 50% 85%,rgba(20,241,149,.1)0%,transparent 40%);
  animation:bgp 18s ease-in-out infinite;}
@keyframes bgp{0%,100%{transform:translate(0,0);}50%{transform:translate(2%,-1%);}}
.grid-bg{position:fixed;inset:0;z-index:1;pointer-events:none;
  background:linear-gradient(rgba(255,255,255,.018)1px,transparent 1px),
             linear-gradient(90deg,rgba(255,255,255,.018)1px,transparent 1px);
  background-size:55px 55px;
  mask-image:radial-gradient(ellipse at center,black 30%,transparent 85%);}
#particles{position:fixed;inset:0;z-index:1;pointer-events:none;width:100%;height:100%;}
.wrap{max-width:980px;margin:0 auto;padding:24px 18px;position:relative;z-index:2;}

/* HEADER */
.hdr{text-align:center;margin-bottom:20px;}
.wm-logo-wrap{display:flex;justify-content:center;margin:4px auto 6px;}
.wm-logo{width:min(330px,62vw);height:auto;display:block;
  mix-blend-mode:lighten;
  filter:drop-shadow(0 8px 30px rgba(56,189,248,.22));
  animation:logoIn .7s cubic-bezier(.2,.8,.2,1) both;}
@keyframes logoIn{from{opacity:0;transform:translateY(-10px) scale(.97);}to{opacity:1;transform:none;}}
.wm-w1{font-family:'Bebas Neue',sans-serif;font-size:74px;fill:#fff;letter-spacing:1px;
  paint-order:stroke;stroke:#0b1024;stroke-width:5px;stroke-linejoin:round;}
.wm-w2{font-family:'Bebas Neue',sans-serif;font-size:74px;fill:#fff;letter-spacing:1px;
  paint-order:stroke;stroke:#0b1024;stroke-width:5px;stroke-linejoin:round;}
.wm-year{font-family:'Bebas Neue',sans-serif;font-size:40px;letter-spacing:2px;font-weight:700;}
.wm-season{font-family:'Bebas Neue',sans-serif;font-size:24px;letter-spacing:5px;fill:#fff;}
.wm-s2{font-family:'Bebas Neue',sans-serif;font-size:46px;fill:#fff;
  paint-order:stroke;stroke:#0b1024;stroke-width:3px;stroke-linejoin:round;}
.hdr-eyebrow{font-size:.68rem;letter-spacing:4px;text-transform:uppercase;color:var(--text2);margin-bottom:8px;}
.hdr-title{font-family:'Bebas Neue',sans-serif;font-size:2.8rem;letter-spacing:10px;
  background:linear-gradient(135deg,var(--blue-bright),var(--violet-glow),var(--green));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;line-height:1;}
.hdr-s2{font-family:'Bebas Neue',sans-serif;font-size:2.9rem;letter-spacing:14px;line-height:1;margin-top:6px;
  background:linear-gradient(135deg,#FB7185,var(--violet),var(--blue-bright),var(--green));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  filter:drop-shadow(0 2px 14px rgba(56,189,248,.35));text-indent:14px;}
@media(max-width:560px){.hdr-s2{font-size:2rem;letter-spacing:8px;text-indent:8px;}}
.hdr-bar{width:140px;height:3px;background:linear-gradient(90deg,#FB7185,var(--violet),var(--blue-glow),var(--green));
  border-radius:3px;margin:12px auto;box-shadow:0 0 18px rgba(56,189,248,.55);}
.hdr-sub{font-size:.72rem;color:var(--text2);letter-spacing:2px;text-transform:uppercase;}
.data-asof{display:inline-flex;align-items:center;gap:7px;margin-top:12px;padding:6px 16px;border-radius:50px;font-size:.72rem;font-weight:700;letter-spacing:.6px;text-transform:uppercase;background:rgba(56,189,248,.1);border:1px solid rgba(56,189,248,.32);color:var(--blue-glow);}
.data-asof b{color:var(--text);font-weight:800;letter-spacing:.4px;}
.hdr-actions{display:flex;align-items:center;justify-content:center;gap:12px;flex-wrap:wrap;margin-top:12px;}
.refresh-btn{display:inline-flex;align-items:center;gap:8px;padding:9px 22px;border-radius:50px;cursor:pointer;
  font-family:'Outfit',sans-serif;font-weight:800;font-size:.76rem;letter-spacing:1.2px;text-transform:uppercase;color:#fff;
  border:1px solid rgba(56,189,248,.5);background:linear-gradient(135deg,rgba(37,99,235,.4),rgba(168,85,247,.34));
  box-shadow:0 4px 16px rgba(37,99,235,.28);transition:.25s;}
.refresh-btn:hover{transform:translateY(-2px);box-shadow:0 7px 24px rgba(56,189,248,.45);border-color:rgba(56,189,248,.85);}
.refresh-btn:active{transform:translateY(0);}
.refresh-btn .ri{font-size:1.05rem;display:inline-block;transition:transform .5s;}
.refresh-btn:hover .ri{transform:rotate(180deg);}
.refresh-meta{font-size:.64rem;color:var(--text2);letter-spacing:1px;margin-top:8px;text-transform:uppercase;}
/* MINI-NAV on detail pages */
.subnav{margin-bottom:18px;}
.subnav-home{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:50px;cursor:pointer;
  font-family:'Outfit',sans-serif;font-weight:800;font-size:.8rem;letter-spacing:1px;text-transform:uppercase;color:#fff;
  border:1px solid rgba(56,189,248,.45);background:linear-gradient(135deg,rgba(37,99,235,.32),rgba(168,85,247,.26));
  box-shadow:0 4px 14px rgba(37,99,235,.22);transition:.22s;margin-bottom:11px;}
.subnav-home:hover{transform:translateY(-2px);border-color:rgba(56,189,248,.8);box-shadow:0 6px 20px rgba(56,189,248,.4);}
.subnav-lbl{font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--text2);margin:2px 0 8px;font-weight:600;}
.subnav-chips{display:flex;gap:8px;flex-wrap:wrap;}
.subnav-chip{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;min-width:84px;
  padding:10px 12px;border-radius:13px;cursor:pointer;background:var(--card-bg);backdrop-filter:blur(12px);
  border:1px solid var(--card-border);transition:.25s;position:relative;overflow:hidden;}
.subnav-chip::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.subnav-chip:hover{transform:translateY(-3px);box-shadow:0 8px 22px rgba(0,0,0,.3);}
.subnav-chip-ico{font-size:1.25rem;line-height:1;}
.subnav-chip-t{font-family:'Bebas Neue',sans-serif;font-size:.86rem;letter-spacing:1.5px;color:var(--text);}
.subnav-chip.nc-stride::before{background:linear-gradient(90deg,#2563EB,#A855F7);}
.subnav-chip.nc-stride:hover{border-color:rgba(37,99,235,.6);}
.subnav-chip.nc-ride::before{background:linear-gradient(90deg,var(--enduro),var(--ascend));}
.subnav-chip.nc-ride:hover{border-color:rgba(251,113,133,.6);}
.subnav-chip.nc-plus1::before{background:linear-gradient(90deg,var(--violet),var(--blue-glow));}
.subnav-chip.nc-plus1:hover{border-color:rgba(168,85,247,.6);}
.subnav-chip.nc-groups::before{background:linear-gradient(90deg,var(--green),#0EA5E9);}
.subnav-chip.nc-groups:hover{border-color:rgba(20,241,149,.6);}
.subnav-chip.nc-mine::before{background:linear-gradient(90deg,var(--blue-bright),var(--violet));}
.subnav-chip.nc-mine:hover{border-color:rgba(0,212,255,.7);}
.live-badge{display:inline-flex;align-items:center;gap:6px;margin-top:10px;padding:6px 16px;border-radius:50px;
  background:rgba(20,241,149,.1);border:1px solid rgba(20,241,149,.35);color:var(--green-glow);
  font-size:.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;}
.dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 1.6s infinite;}
@keyframes pulse{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.35;transform:scale(.65);}}

/* HERO STATS */
/* HERO PROGRESS PILLS (header only) */
.hero-pills{display:flex;justify-content:center;gap:8px;margin-bottom:14px;}
.hero-pill{display:inline-flex;align-items:center;gap:5px;padding:5px 13px;border-radius:50px;
  font-size:.72rem;font-weight:700;letter-spacing:.5px;backdrop-filter:blur(10px);}
.hp-km{background:rgba(20,241,149,.1);border:1px solid rgba(20,241,149,.3);color:var(--green-glow);}
.hp-fin{background:rgba(255,215,0,.1);border:1px solid rgba(255,215,0,.3);color:var(--gold);}

/* WEEK SELECTOR */
.week-bar{background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid var(--card-border);
  border-radius:12px;padding:12px 14px;margin-bottom:16px;}
.week-bar-lbl{font-size:.63rem;letter-spacing:2.5px;text-transform:uppercase;color:var(--text2);margin-bottom:8px;font-weight:600;}
.week-btns{display:flex;gap:4px;flex-wrap:wrap;}
.wbtn{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);color:var(--text2);
  padding:5px 9px;border-radius:7px;font-size:.68rem;font-weight:600;cursor:pointer;transition:.2s;
  font-family:'Outfit',sans-serif;white-space:nowrap;}
.wbtn:hover{background:rgba(56,189,248,.15);color:var(--text);border-color:rgba(56,189,248,.35);}
.wbtn.active{background:linear-gradient(135deg,var(--blue),var(--violet));color:#fff;border-color:transparent;
  box-shadow:0 2px 10px rgba(37,99,235,.4);}
.wbtn.has-data:not(.active){color:var(--green-glow);border-color:rgba(20,241,149,.4);}
.week-info{margin-top:6px;font-size:.7rem;color:var(--text2);min-height:14px;}

/* PANES */
.pane{display:none;animation:fadeUp .3s ease-out;}
.pane.active{display:block;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px);}to{opacity:1;transform:translateY(0);}}

/* BACK BUTTON */
.back-btn{display:inline-flex;align-items:center;gap:7px;margin-bottom:16px;padding:8px 18px;
  background:var(--card-bg);backdrop-filter:blur(10px);border:1px solid var(--card-border);
  border-radius:50px;color:var(--text2);font-size:.78rem;font-weight:700;cursor:pointer;
  font-family:'Outfit',sans-serif;transition:.22s;text-transform:uppercase;letter-spacing:.8px;}
.back-btn:hover{border-color:rgba(56,189,248,.5);color:var(--text);background:rgba(56,189,248,.1);}

/* BIG NAV CARDS — Landing Page */
.nav-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:20px;}
.nav-card{background:linear-gradient(160deg,rgba(20,28,54,.78),rgba(10,15,32,.72));backdrop-filter:blur(18px);border:1px solid var(--card-border);
  border-radius:18px;padding:24px 16px;text-align:center;cursor:pointer;transition:transform .35s cubic-bezier(.2,.8,.2,1),box-shadow .35s,border-color .35s;position:relative;overflow:hidden;
  display:flex;flex-direction:column;align-items:center;}
.nav-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% -20%,rgba(255,255,255,.07),transparent 60%);pointer-events:none;}
.nav-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:18px 18px 0 0;}
.nav-card:hover{transform:translateY(-6px) scale(1.015);}
.nav-card-icon{font-size:2.4rem;margin-bottom:10px;display:block;}
.nav-card-title{font-family:'Bebas Neue',sans-serif;font-size:1.35rem;letter-spacing:3px;margin-bottom:5px;}
.nav-card-meta{font-size:.68rem;color:var(--text2);letter-spacing:.5px;}
.nav-card-stat{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;margin-top:8px;margin-bottom:13px;}
.nav-card{user-select:none;}
.nav-card:active{transform:translateY(-2px) scale(.99);}
.nav-card-go{position:absolute;top:12px;right:12px;width:26px;height:26px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;font-size:.95rem;font-weight:800;line-height:1;
  background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.16);color:var(--text2);transition:.3s;}
.nav-card:hover .nav-card-go{background:rgba(56,189,248,.22);border-color:rgba(56,189,248,.55);color:#fff;transform:translateX(2px);}
.nav-card-cta{display:inline-flex;align-items:center;gap:7px;margin-top:auto;padding:7px 17px;border-radius:50px;
  font-size:.7rem;font-weight:800;letter-spacing:1.3px;text-transform:uppercase;font-family:'Outfit',sans-serif;
  color:var(--text);background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);
  transition:.3s;animation:tapHint 2.2s ease-in-out 3;}
.nav-card-cta .ar{transition:transform .3s;}
.nav-card:hover .nav-card-cta{background:rgba(56,189,248,.2);border-color:rgba(56,189,248,.55);
  box-shadow:0 4px 16px rgba(56,189,248,.28);color:#fff;}
.nav-card:hover .nav-card-cta .ar{transform:translateX(4px);}
@keyframes tapHint{0%,100%{box-shadow:0 0 0 0 rgba(56,189,248,0);}50%{box-shadow:0 0 0 5px rgba(56,189,248,.16);}}

/* Card color schemes */
.nc-stride::before{background:linear-gradient(90deg,#2563EB,#A855F7);}
.nc-stride{border-color:rgba(37,99,235,.3);}
.nc-stride:hover{border-color:rgba(37,99,235,.6);box-shadow:0 12px 40px rgba(37,99,235,.2);}
.nc-stride .nav-card-title{color:#93C5FD;}
.nc-stride .nav-card-stat{color:var(--blue-bright);}

.nc-ride::before{background:linear-gradient(90deg,var(--enduro),var(--ascend));}
.nc-ride{border-color:rgba(251,113,133,.3);}
.nc-ride:hover{border-color:rgba(251,113,133,.6);box-shadow:0 12px 40px rgba(251,113,133,.2);}
.nc-ride .nav-card-title{color:#FCA5A5;}
.nc-ride .nav-card-stat{color:var(--ascend);}

.nc-plus1::before{background:linear-gradient(90deg,var(--violet),var(--blue-glow));}
.nc-plus1{border-color:rgba(168,85,247,.3);}
.nc-plus1:hover{border-color:rgba(168,85,247,.6);box-shadow:0 12px 40px rgba(168,85,247,.2);}
.nc-plus1 .nav-card-title{color:var(--violet-glow);}
.nc-plus1 .nav-card-stat{color:#C4B5FD;}

.nc-groups::before{background:linear-gradient(90deg,var(--green),#0EA5E9);}
.nc-groups{border-color:rgba(20,241,149,.3);}
.nc-groups:hover{border-color:rgba(20,241,149,.6);box-shadow:0 12px 40px rgba(20,241,149,.15);}
.nc-groups .nav-card-title{color:var(--green-glow);}
.nc-groups .nav-card-stat{color:var(--green);}

.nc-mine{border-color:rgba(0,212,255,.4);animation:mineCardGlow 2.8s ease-in-out infinite;}
.nc-mine::before{background:linear-gradient(90deg,var(--blue-bright),var(--violet));}
.nc-mine:hover{border-color:rgba(0,212,255,.9);box-shadow:0 12px 40px rgba(0,212,255,.25);animation:none;}
.nc-mine .nav-card-title{color:var(--blue-bright);}
.nc-mine .nav-card-stat{color:var(--violet-glow);}
@keyframes mineCardGlow{
  0%,100%{box-shadow:0 0 16px rgba(0,212,255,.1);}
  50%{box-shadow:0 0 32px rgba(0,212,255,.3),0 0 60px rgba(168,85,247,.1);}
}

/* HOME TOP 10 DUAL PANEL */
.home-top10{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
@media(max-width:640px){.home-top10{grid-template-columns:1fr;}}

/* COMBINED KM TARGET & ACHIEVED — moving banner */
.combined-banner{position:relative;overflow:hidden;border-radius:20px;padding:26px 20px;text-align:center;margin-bottom:18px;
  background:linear-gradient(150deg,rgba(20,28,54,.85),rgba(10,15,32,.8));border:1px solid var(--card-border);backdrop-filter:blur(16px);}
.combined-banner::before{content:'';position:absolute;inset:-60%;pointer-events:none;z-index:0;
  background:conic-gradient(from 0deg,transparent 0deg,rgba(0,212,255,.05) 55deg,rgba(168,85,247,.06) 140deg,rgba(20,241,149,.05) 225deg,transparent 310deg);
  animation:cb-rotate 30s linear infinite;}
@keyframes cb-rotate{to{transform:rotate(360deg);}}
.cb-inner{position:relative;z-index:1;}
.cb-eyebrow{font-size:.68rem;letter-spacing:4px;text-transform:uppercase;color:var(--text2);margin-bottom:8px;}
.cb-big{font-family:'Bebas Neue',sans-serif;font-size:clamp(2.6rem,8vw,4.4rem);line-height:1;letter-spacing:2px;
  background:linear-gradient(90deg,var(--blue-bright),var(--violet-glow),var(--green),var(--blue-bright));
  background-size:300% 100%;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;color:transparent;
  animation:none;}
.cb-big .cb-unit{font-size:.45em;letter-spacing:3px;-webkit-text-fill-color:var(--text2);color:var(--text2);}
@keyframes cb-flow{to{background-position:300% 0;}}
.cb-achieved{font-family:'Outfit',sans-serif;font-weight:700;font-size:.9rem;color:var(--text);margin-top:10px;}
.cb-achieved .cb-ach-num{color:var(--green);}
.cb-bar{width:min(420px,82%);height:8px;border-radius:50px;background:rgba(255,255,255,.08);margin:12px auto 0;overflow:hidden;}
.cb-bar-fill{height:100%;border-radius:50px;width:0;background:linear-gradient(90deg,var(--blue-bright),var(--green));
  background-size:200% 100%;animation:cb-flow 3s linear infinite;transition:width 1.4s cubic-bezier(.2,.8,.2,1);}
.cb-breakdown{margin-top:12px;font-family:'Outfit',sans-serif;font-weight:700;font-size:.82rem;color:var(--text);}
.cb-breakdown .s{color:var(--blue-bright);}
.cb-breakdown .r{color:var(--ascend);}
.cb-breakdown .dot{opacity:.5;margin:0 8px;}
.cb-foot{margin-top:7px;font-size:.7rem;color:var(--text2);letter-spacing:.4px;}
.light .combined-banner{background:linear-gradient(150deg,#ffffff,#eef2f9);box-shadow:0 8px 24px rgba(15,23,42,.08);}
.light .cb-achieved{color:#0F172A;}
.light .cb-breakdown{color:#0F172A;}
@media(prefers-reduced-motion:reduce){.combined-banner::before,.cb-big,.cb-bar-fill,.nc-mine,.nav-card-cta,.wm-logo,.dot,.bg::before{animation:none!important;}}

/* TOP 10 PANELS (shared) */
.top10-card{background:linear-gradient(165deg,rgba(18,26,50,.78),rgba(10,15,32,.72));backdrop-filter:blur(14px);border:1px solid var(--card-border);
  border-radius:14px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.22);}
.top10-hdr{display:flex;align-items:center;gap:10px;padding:13px 16px;
  border-bottom:1px solid rgba(255,255,255,.07);}
.top10-hdr-icon{font-size:1.3rem;}
.top10-hdr-title{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:2.5px;}
.top10-hdr-sub{font-size:.64rem;color:var(--text2);margin-left:auto;}
.top10-body{padding:4px 0;}
.top10-row{display:flex;align-items:center;gap:9px;padding:9px 14px;transition:.15s;border-bottom:1px solid rgba(255,255,255,.03);}
.top10-row:last-child{border-bottom:none;}
.top10-row:hover{background:rgba(56,189,248,.05);}
.top10-row.finished{background:linear-gradient(90deg,rgba(255,215,0,.07),rgba(20,241,149,.04));box-shadow:inset 3px 0 0 var(--gold);}
.top10-cat-badge{font-size:.58rem;font-weight:700;padding:2px 7px;border-radius:50px;flex-shrink:0;}
.sex-chip{font-size:.58rem;font-weight:700;padding:2px 6px;border-radius:50px;flex-shrink:0;}
.sex-chip-m{background:rgba(56,189,248,.15);border:1px solid rgba(56,189,248,.3);color:#38BDF8;}
.sex-chip-f{background:rgba(244,114,182,.15);border:1px solid rgba(244,114,182,.3);color:#F472B6;}

/* CATEGORY SECTIONS - collapsible */
.cat-section{margin-bottom:8px;}
.cat-section-hdr{display:flex;align-items:center;gap:10px;padding:13px 16px;
  background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid var(--card-border);
  border-radius:12px;cursor:pointer;transition:.25s;user-select:none;}
.cat-section-hdr:hover{border-color:rgba(56,189,248,.4);background:rgba(13,19,38,0.88);}
.cat-section-hdr.open{border-radius:12px 12px 0 0;border-bottom-color:transparent;}
.cat-section-icon{font-size:1.25rem;flex-shrink:0;}
.cat-section-name{font-family:'Bebas Neue',sans-serif;font-size:1.25rem;letter-spacing:3px;}
.cat-section-goal{font-size:.68rem;color:var(--text2);letter-spacing:.8px;}
.cat-section-counts{display:flex;gap:5px;margin-left:auto;flex-shrink:0;}
.cnt-m{font-size:.66rem;padding:2px 8px;border-radius:50px;
  background:rgba(56,189,248,.15);border:1px solid rgba(56,189,248,.3);color:#38BDF8;}
.cnt-f{font-size:.66rem;padding:2px 8px;border-radius:50px;
  background:rgba(244,114,182,.15);border:1px solid rgba(244,114,182,.3);color:#F472B6;}
.cat-chevron{font-size:.72rem;color:var(--text2);transition:transform .28s;flex-shrink:0;}
.cat-section-hdr.open .cat-chevron{transform:rotate(180deg);}
.gender-pair{display:none;grid-template-columns:1fr 1fr;gap:0;
  border:1px solid var(--card-border);border-top:none;border-radius:0 0 12px 12px;overflow:hidden;}
.gender-pair.open{display:grid;}
@media(max-width:640px){.gender-pair.open{grid-template-columns:1fr;}}

/* GENDER PANELS */
.cat-panel{background:var(--card-bg);backdrop-filter:blur(14px);
  border-right:1px solid rgba(255,255,255,.06);overflow:hidden;}
.cat-panel:last-child{border-right:none;}
@media(max-width:640px){.cat-panel{border-right:none;border-bottom:1px solid rgba(255,255,255,.06);}
.cat-panel:last-child{border-bottom:none;}}
.cat-hdr{padding:10px 14px 8px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid rgba(255,255,255,.06);}
.cat-hdr-left{display:flex;align-items:center;gap:7px;}
.sex-badge{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.9rem;flex-shrink:0;}
.sex-m{background:rgba(56,189,248,.18);border:1px solid rgba(56,189,248,.38);}
.sex-f{background:rgba(244,114,182,.18);border:1px solid rgba(244,114,182,.38);}
.sex-lbl{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:2px;}
.sex-m-lbl{color:#38BDF8;}
.sex-f-lbl{color:#F472B6;}
.cat-count{font-size:.66rem;color:var(--text2);background:rgba(255,255,255,.07);padding:2px 7px;border-radius:50px;}
.cat-list{padding:3px 0;}
.cat-row{display:flex;align-items:center;gap:8px;padding:8px 14px;transition:.15s;}
.cat-row:hover{background:rgba(56,189,248,.05);}
.cat-row.finished{background:linear-gradient(90deg,rgba(255,215,0,.08),rgba(20,241,149,.05));box-shadow:inset 3px 0 0 var(--gold);}
.rank-ico{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;
  font-weight:800;font-size:.72rem;flex-shrink:0;}
.r1{background:linear-gradient(135deg,#FFD700,#FFA500);color:#1a0f00;box-shadow:0 0 8px rgba(255,215,0,.35);}
.r2{background:linear-gradient(135deg,#C0C0C0,#A0A0A0);color:#1a1a1a;}
.r3{background:linear-gradient(135deg,#CD7F32,#A0522D);color:#fff;}
.rn{background:rgba(255,255,255,.1);color:var(--text2);}
.cat-row-info{flex:1;min-width:0;}
.cat-row-name{font-weight:600;font-size:.83rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.cat-row-sub{font-size:.65rem;color:var(--text2);margin-top:1px;}
.cat-row-right{text-align:right;flex-shrink:0;}
.cat-km{font-family:'Bebas Neue',sans-serif;font-size:1rem;letter-spacing:.5px;}
.cat-pct{font-size:.62rem;color:var(--text2);margin-top:1px;}
.cat-prog{height:2px;border-radius:2px;margin-top:4px;background:rgba(255,255,255,.08);}
.cat-prog-fill{height:100%;border-radius:2px;transition:width .5s ease;}
.fin-tag{display:inline-flex;align-items:center;gap:3px;font-size:.54rem;font-weight:800;letter-spacing:.6px;
  padding:1px 7px 1px 5px;border-radius:50px;vertical-align:middle;margin-left:5px;text-transform:uppercase;
  background:linear-gradient(135deg,rgba(255,215,0,.22),rgba(255,165,0,.18));
  border:1px solid rgba(255,215,0,.55);color:#FFD700;box-shadow:0 0 8px rgba(255,215,0,.28);}

/* PLUS 1 LIST */
.p1-card{background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid rgba(168,85,247,.25);
  border-radius:14px;overflow:hidden;max-width:580px;margin:0 auto;}
.p1-hdr{padding:12px 16px;background:rgba(168,85,247,.1);border-bottom:1px solid rgba(255,255,255,.07);
  display:flex;align-items:center;gap:10px;}
.p1-hdr-title{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:2px;color:var(--violet-glow);}
.p1-hdr-count{margin-left:auto;font-size:.68rem;color:var(--text2);}

/* GROUP MEMBER PANEL */
.g-toggle{display:flex;align-items:center;justify-content:center;gap:6px;width:100%;
  padding:8px 0;background:transparent;border:none;border-top:1px solid rgba(255,255,255,.07);
  color:var(--text2);font-size:.65rem;font-family:'Outfit',sans-serif;letter-spacing:1px;
  text-transform:uppercase;cursor:pointer;transition:.2s;}
.g-toggle:hover{background:rgba(255,255,255,.06);color:var(--text);}
.g-members{display:none;border-top:1px solid rgba(255,255,255,.06);}
.g-members.open{display:block;}
.g-member-row{display:flex;align-items:center;gap:7px;padding:7px 14px;
  border-bottom:1px solid rgba(255,255,255,.04);}
.g-member-row:last-child{border-bottom:none;}
.g-member-rank{font-size:.62rem;color:var(--text2);width:14px;text-align:right;flex-shrink:0;}
.g-member-check{width:18px;height:18px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:.65rem;line-height:1;}
.g-member-check.has-km{background:rgba(20,241,149,.2);border:1.5px solid var(--green);color:var(--green);}
.g-member-check.no-km{background:transparent;border:1.5px solid rgba(255,255,255,.18);color:transparent;}
.g-member-info{flex:1;min-width:0;}
.g-member-name{font-size:.74rem;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.g-member-prog{display:flex;align-items:center;gap:5px;margin-top:3px;}
.g-member-bar-bg{flex:1;height:3px;background:rgba(255,255,255,.08);border-radius:50px;overflow:hidden;}
.g-member-bar-fill{height:100%;border-radius:50px;transition:width .6s ease;}
.g-member-km-lbl{font-size:.6rem;color:var(--text2);flex-shrink:0;white-space:nowrap;}
.g-member-badge{font-size:.53rem;font-weight:700;letter-spacing:.8px;text-transform:uppercase;
  padding:2px 7px;border-radius:50px;flex-shrink:0;}

/* GROUP CARDS */
.group-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:12px;}
.g-card{background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid var(--card-border);
  border-radius:14px;padding:16px;transition:.3s;}
.g-card:hover{transform:translateY(-3px);border-color:rgba(56,189,248,.35);box-shadow:0 8px 28px rgba(0,0,0,.28);}
.g-card-hdr{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:10px;}
.g-card-name{font-family:'Bebas Neue',sans-serif;font-size:1.1rem;letter-spacing:2px;}
.g-card-meta{font-size:.68rem;color:var(--text2);margin-top:2px;}
.g-rank{font-family:'Bebas Neue',sans-serif;font-size:1.7rem;opacity:.26;}
.g-stats{display:grid;grid-template-columns:1fr 1fr 1fr;gap:7px;margin-bottom:10px;text-align:center;}
.g-sv{font-family:'Bebas Neue',sans-serif;font-size:1.2rem;letter-spacing:.5px;}
.g-sl{font-size:.58rem;color:var(--text2);text-transform:uppercase;letter-spacing:.8px;margin-top:2px;}
.g-prog-wrap{background:rgba(255,255,255,.07);border-radius:50px;height:6px;overflow:hidden;margin-bottom:4px;}
.g-prog{height:100%;border-radius:50px;transition:width .8s ease;}
.g-prog-lbl{display:flex;justify-content:space-between;font-size:.62rem;color:var(--text2);}

/* MY PROGRESS */
.search-bar{background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid rgba(0,212,255,.3);
  border-radius:12px;padding:12px 14px;margin-bottom:14px;box-shadow:0 0 20px rgba(0,212,255,.08);}
.search-inner{display:flex;gap:10px;align-items:center;flex-wrap:wrap;}
.search-input{background:rgba(0,212,255,.07);border:1px solid rgba(0,212,255,.3);color:var(--text);
  padding:9px 16px;border-radius:50px;font-size:.86rem;font-family:'Outfit',sans-serif;
  flex:1;min-width:180px;outline:none;transition:.25s;}
.search-input::placeholder{color:var(--text2);}
.search-input:focus{border-color:rgba(0,212,255,.7);background:rgba(0,212,255,.12);}
.search-clear{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:var(--text2);
  padding:7px 13px;border-radius:50px;font-size:.72rem;cursor:pointer;font-family:'Outfit',sans-serif;transition:.2s;}
.search-clear:hover{background:rgba(251,113,133,.2);color:var(--enduro);}
.my-result{display:none;}
.my-result.visible{display:block;}
.my-card{background:var(--card-bg);backdrop-filter:blur(14px);border:1px solid rgba(0,212,255,.3);
  border-radius:14px;overflow:hidden;box-shadow:0 6px 28px rgba(0,212,255,.1);margin-bottom:12px;}
.my-card-hdr{padding:16px 20px;border-bottom:1px solid rgba(255,255,255,.07);
  background:linear-gradient(135deg,rgba(0,212,255,.12),rgba(168,85,247,.09));}
.my-name{font-family:'Bebas Neue',sans-serif;font-size:1.8rem;letter-spacing:3px;}
.my-meta{font-size:.75rem;color:var(--text2);margin-top:3px;}
.my-stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(100px,1fr));gap:10px;
  padding:14px 20px;border-bottom:1px solid rgba(255,255,255,.05);}
.my-stat{text-align:center;}
.my-stat-val{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:.5px;}
.my-stat-lbl{font-size:.6rem;color:var(--text2);text-transform:uppercase;letter-spacing:1px;margin-top:2px;}
.my-prog-bar{height:6px;background:rgba(255,255,255,.08);border-radius:50px;margin:14px 20px 0;overflow:hidden;}
.my-prog-fill{height:100%;border-radius:50px;transition:width .8s ease;}
.my-weeks{padding:14px 20px;}
.my-wk-lbl{font-size:.62rem;letter-spacing:2px;text-transform:uppercase;color:var(--text2);margin-bottom:8px;font-weight:600;}
.my-wk-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:6px;}
.my-wk{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);border-radius:8px;
  padding:8px 5px;text-align:center;transition:.2s;}
.my-wk.has-km{background:rgba(0,212,255,.13);border-color:rgba(0,212,255,.36);}
.my-wk.cur-wk{border-color:rgba(0,212,255,.58);box-shadow:0 0 9px rgba(0,212,255,.16);}
.my-wk-num{font-size:.56rem;color:var(--text2);letter-spacing:1px;text-transform:uppercase;}
.my-wk-km{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;color:var(--text2);margin:2px 0;}
.my-wk.has-km .my-wk-km{color:var(--blue-bright);}
.my-wk-date{font-size:.52rem;color:var(--text2);opacity:.45;}
.my-not-found{padding:26px;text-align:center;color:var(--text2);}

/* DISPUTE FORM */
.dispute-card{background:var(--card-bg);backdrop-filter:blur(14px);
  border:1px solid rgba(251,191,36,.28);border-radius:14px;overflow:hidden;box-shadow:0 4px 20px rgba(251,191,36,.05);}
.dispute-hdr{padding:12px 18px;background:linear-gradient(135deg,rgba(251,191,36,.09),rgba(251,113,133,.06));
  border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;gap:9px;}
.dispute-hdr-icon{font-size:1.1rem;}
.dispute-hdr-title{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;letter-spacing:2.5px;color:var(--ascend);}
.dispute-hdr-sub{font-size:.65rem;color:var(--text2);margin-left:auto;}
.dispute-body{padding:16px 18px;}
.dispute-note{font-size:.72rem;color:var(--text2);margin-bottom:12px;line-height:1.6;
  background:rgba(251,191,36,.05);border-left:2px solid rgba(251,191,36,.4);
  padding:8px 11px;border-radius:0 7px 7px 0;}
.d-fields{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:9px;}
@media(max-width:520px){.d-fields{grid-template-columns:1fr;}}
.d-field{display:flex;flex-direction:column;gap:4px;}
.d-field.full{grid-column:1/-1;}
.d-label{font-size:.62rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--text2);font-weight:600;}
.d-input,.d-textarea{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.13);
  color:var(--text);padding:8px 12px;border-radius:8px;font-size:.82rem;font-family:'Outfit',sans-serif;
  outline:none;transition:.22s;width:100%;}
.d-input:focus,.d-textarea:focus{border-color:rgba(251,191,36,.6);background:rgba(251,191,36,.06);}
/* Correct-KM emphasis */
.d-correct-field{background:rgba(20,241,149,.07);border:1px solid rgba(20,241,149,.45);border-radius:10px;padding:8px 10px;box-shadow:0 0 0 1px rgba(20,241,149,.15) inset;}
.d-correct-field .d-label{color:var(--green-glow);}
.d-correct-input{border-color:rgba(20,241,149,.55)!important;background:rgba(20,241,149,.05)!important;font-weight:700;}
.d-correct-input:focus{border-color:var(--green)!important;background:rgba(20,241,149,.1)!important;}
.d-correct-tag{display:inline-block;margin-left:6px;font-size:.55rem;font-weight:700;letter-spacing:.5px;color:var(--green);background:rgba(20,241,149,.14);border:1px solid rgba(20,241,149,.3);padding:1px 7px;border-radius:50px;text-transform:none;}
/* Proof upload */
.d-file-row{display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.d-file-btn{display:inline-flex;align-items:center;background:rgba(56,189,248,.15);color:var(--blue-glow);border:1px solid rgba(56,189,248,.35);border-radius:8px;padding:7px 14px;font-family:'Outfit',sans-serif;font-weight:600;font-size:.78rem;cursor:pointer;white-space:nowrap;transition:.2s;}
.d-file-btn:hover{background:rgba(56,189,248,.25);border-color:rgba(56,189,248,.6);}
.d-file-name{font-size:.74rem;color:var(--text2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:60%;}
.d-file-hint{font-size:.62rem;color:var(--text2);margin-top:4px;}
.d-file-ok{color:var(--green)!important;font-weight:700;}
.d-proof-thumb{margin-top:8px;max-height:92px;max-width:170px;border-radius:8px;border:1px solid rgba(20,241,149,.45);display:block;}
.d-textarea{resize:vertical;min-height:68px;}
.d-file-wrap{background:rgba(255,255,255,.04);border:1px dashed rgba(255,255,255,.18);
  border-radius:8px;padding:11px 12px;text-align:center;cursor:pointer;transition:.22s;position:relative;}
.d-file-wrap:hover{border-color:rgba(251,191,36,.5);background:rgba(251,191,36,.05);}
.d-file-note{font-size:.68rem;color:var(--text2);margin-top:3px;}
.d-file-name{font-size:.72rem;color:var(--ascend);margin-top:4px;font-weight:600;display:none;}
.d-input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;}
.d-btn{margin-top:12px;width:100%;padding:11px;border-radius:50px;font-size:.84rem;font-weight:800;
  font-family:'Outfit',sans-serif;letter-spacing:1px;cursor:pointer;border:none;
  background:linear-gradient(135deg,#F59E0B,#EF4444);color:#fff;
  box-shadow:0 4px 16px rgba(245,158,11,.3);transition:.25s;text-transform:uppercase;}
.d-btn:hover{transform:translateY(-2px);box-shadow:0 6px 24px rgba(245,158,11,.45);}
.d-sent{display:none;padding:14px;text-align:center;color:var(--green);font-weight:700;font-size:.84rem;}

.empty{padding:36px 20px;text-align:center;color:var(--text2);}
.empty-icon{font-size:2rem;margin-bottom:8px;}
.empty-text{font-size:.8rem;line-height:1.6;}
.footer{text-align:center;font-size:.66rem;color:rgba(255,255,255,.32);margin-top:26px;letter-spacing:.6px;}
.footer strong{color:rgba(255,255,255,.5);font-weight:700;letter-spacing:1px;}
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-track{background:rgba(255,255,255,.04);}
::-webkit-scrollbar-thumb{background:rgba(56,189,248,.3);border-radius:3px;}

/* ===== TOP CONTROL BAR ===== */
.topbar{position:static;z-index:120;display:flex;gap:8px;align-items:center;justify-content:flex-end;margin:0 0 18px;}
.tb-btn{position:relative;display:inline-flex;align-items:center;justify-content:center;width:42px;height:42px;padding:0;border-radius:50%;cursor:pointer;
  color:var(--text);background:var(--card-bg);backdrop-filter:blur(12px);border:1px solid var(--card-border);transition:.22s;}
.tb-btn:hover{transform:translateY(-2px);border-color:rgba(56,189,248,.6);box-shadow:0 6px 18px rgba(56,189,248,.22);color:#fff;}
.light .tb-btn:hover{color:#0F172A;}
.tb-txt{display:none;}
.tb-ico{font-size:1.15rem;line-height:1;}
/* hover tooltip */
.tb-btn::after{content:attr(data-tip);position:absolute;top:calc(100% + 9px);left:50%;transform:translateX(-50%) translateY(4px);
  background:#0b1024;color:#fff;font-family:'Outfit',sans-serif;font-weight:700;font-size:.66rem;letter-spacing:.6px;text-transform:uppercase;
  padding:6px 11px;border-radius:8px;white-space:nowrap;border:1px solid rgba(56,189,248,.35);box-shadow:0 6px 18px rgba(0,0,0,.35);
  opacity:0;pointer-events:none;transition:opacity .18s,transform .18s;z-index:200;}
.tb-btn::before{content:'';position:absolute;top:calc(100% + 3px);left:50%;transform:translateX(-50%) translateY(4px);
  border:5px solid transparent;border-bottom-color:#0b1024;opacity:0;pointer-events:none;transition:opacity .18s,transform .18s;z-index:200;}
.tb-btn:hover::after,.tb-btn:focus-visible::after{opacity:1;transform:translateX(-50%) translateY(0);}
.tb-btn:hover::before,.tb-btn:focus-visible::before{opacity:1;transform:translateX(-50%) translateY(0);}
.light .tb-btn::after{background:#0F172A;}
.light .tb-btn::before{border-bottom-color:#0F172A;}
@media(max-width:780px){.topbar{justify-content:center;flex-wrap:wrap;margin:0 0 14px;}}

/* ===== MODAL ===== */
.modal-overlay{position:fixed;inset:0;z-index:200;background:rgba(3,6,15,.74);backdrop-filter:blur(6px);
  display:none;align-items:flex-start;justify-content:center;padding:56px 16px;overflow-y:auto;}
.modal-overlay.open{display:flex;}
.modal{background:linear-gradient(165deg,#111a30,#0a0f20);border:1px solid var(--card-border);border-radius:18px;
  max-width:560px;width:100%;padding:24px 24px 26px;position:relative;box-shadow:0 22px 60px rgba(0,0,0,.55);
  animation:fadeUp .3s ease-out;}
.light .modal{background:linear-gradient(165deg,#ffffff,#eef2f9);box-shadow:0 22px 60px rgba(15,23,42,.22);}
.modal-x{position:absolute;top:13px;right:15px;background:rgba(255,255,255,.06);border:1px solid var(--card-border);
  color:var(--text2);width:30px;height:30px;border-radius:50%;font-size:1.2rem;line-height:1;cursor:pointer;transition:.2s;}
.modal-x:hover{background:rgba(251,113,133,.18);color:var(--enduro);border-color:rgba(251,113,133,.4);}
.light .modal-x{background:rgba(15,23,42,.05);}
.modal-title{font-family:'Bebas Neue',sans-serif;font-size:1.9rem;letter-spacing:3px;line-height:1;
  color:var(--text);padding-right:36px;}
.modal-sub{font-size:.72rem;color:var(--text2);margin:5px 0 16px;letter-spacing:.4px;}
.modal-body{font-size:.86rem;color:var(--text);line-height:1.6;}
.fin-row{display:flex;align-items:center;gap:11px;padding:10px 13px;border-radius:11px;margin-bottom:7px;
  background:rgba(20,241,149,.07);border:1px solid rgba(20,241,149,.2);}
.fin-rank{font-family:'Bebas Neue',sans-serif;font-size:1.05rem;width:26px;height:26px;flex-shrink:0;border-radius:50%;
  display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#FFD700,#FFA500);color:#1a0f00;}
.fin-km{font-family:'Bebas Neue',sans-serif;font-size:1.15rem;letter-spacing:.5px;color:var(--green);flex-shrink:0;}
.modal-empty{text-align:center;padding:30px 12px;color:var(--text2);font-size:.86rem;line-height:1.7;}
.modal-empty .big{font-size:2.4rem;display:block;margin-bottom:10px;}
.modal-body code{background:rgba(56,189,248,.14);border:1px solid rgba(56,189,248,.3);
  padding:1px 6px;border-radius:5px;font-size:.8rem;color:var(--blue-bright);}

/* ===== LIGHT THEME ===== */
body.light{--darker:#EAF0F8;--card-bg:rgba(255,255,255,.9);--card-border:rgba(15,23,42,.12);
  --text:#0F172A;--text2:rgba(15,23,42,.7);}
.light .bg::before{opacity:.45;}
.light .grid-bg{background:linear-gradient(rgba(15,23,42,.05)1px,transparent 1px),
  linear-gradient(90deg,rgba(15,23,42,.05)1px,transparent 1px);background-size:55px 55px;}
.light .wm-logo-wrap{background:linear-gradient(150deg,#101936 0%,#1b1448 55%,#0d1330 100%);
  border:1px solid rgba(120,170,255,.25);border-radius:26px;
  padding:18px 34px;width:max-content;max-width:100%;
  box-shadow:0 14px 40px rgba(56,89,180,.28),inset 0 1px 0 rgba(255,255,255,.08);}
.light .wm-logo{mix-blend-mode:normal;filter:none;}
.light .nav-card{background:linear-gradient(160deg,#ffffff,#eef3fb);}
.light .nav-card::after{background:radial-gradient(circle at 50% -20%,rgba(15,23,42,.05),transparent 60%);}
.light .top10-card{background:linear-gradient(165deg,#ffffff,#eef2f9);box-shadow:0 8px 24px rgba(15,23,42,.08);}
.light .nav-card-cta{background:rgba(15,23,42,.06);border-color:rgba(15,23,42,.16);color:var(--text);}
.light .nav-card:hover .nav-card-cta{color:#fff;}
.light .hdr-sub,.light .footer{color:rgba(15,23,42,.5);}
/* light: convert subtle white fills/tracks to dark-alpha so they stay visible */
.light .my-wk,.light .search-clear,.light .cat-count,.light .rn,.light .g-member-check.no-km{
  background:rgba(15,23,42,.05);border-color:rgba(15,23,42,.14);}
.light .my-prog-bar,.light .g-prog-wrap,.light .cat-prog,.light .g-member-bar-bg,.light .my-prog-bar{
  background:rgba(15,23,42,.1);}
.light .week-bar,.light .cat-section-hdr,.light .g-card,.light .p1-card,.light .search-bar,.light .dispute-card,.light .my-card{
  box-shadow:0 6px 20px rgba(15,23,42,.07);}

/* ===== A11Y FOCUS ===== */
*:focus-visible{outline:2px solid var(--blue-bright);outline-offset:2px;border-radius:4px;}
